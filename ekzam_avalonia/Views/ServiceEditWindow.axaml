<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="ekzam_avalonia.Views.ServiceEditWindow"
        mc:Ignorable="d"
        Width="500"
        Height="420"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="Услуга">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" Margin="16">
    <TextBlock Grid.Row="0" Text="Название:" />
    <TextBox Grid.Row="1" Name="nameTextBox" Margin="0,6,0,10" />

    <TextBlock Grid.Row="2" Text="Цена:" />
    <TextBox Grid.Row="3" Name="priceTextBox" Margin="0,6,0,10" />

    <TextBlock Grid.Row="4" Text="Коллекция:" />
    <ComboBox Grid.Row="5" Name="collectionComboBox" Margin="0,6,0,10" DisplayMemberBinding="{Binding Name}" />

    <TextBlock Grid.Row="6" Text="Картинка:" />
    <ComboBox Grid.Row="7" Name="imageComboBox" Margin="0,6,0,10" />

    <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Content="Сохранить" Width="120" Click="SaveClick" />
      <Button Content="Отмена" Width="120" Margin="8,0,0,0" Click="CancelClick" />
    </StackPanel>
  </Grid>
</Window>
